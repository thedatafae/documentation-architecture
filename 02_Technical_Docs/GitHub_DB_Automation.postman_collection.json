  "item": [
    {
      "name": "01_Schema_Validation",
      "item": [
        {
          "name": "Check User Table Structure",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 1. Status Code Check (Bridge Stability)\r",
                  "pm.test(\"Bridge Connection: Success\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "var schema = pm.response.json();\r",
                  "\r",
                  "// 2. Column Existence & Type Check\r",
                  "pm.test(\"Schema: Verify Columns and Data Types\", function () {\r",
                  "    const expectedSchema = [\r",
                  "        { Field: 'id', Type: 'int' },\r",
                  "        { Field: 'username', Type: 'varchar(50)' },\r",
                  "        { Field: 'email', Type: 'varchar(100)' },\r",
                  "        { Field: 'status', Type: \"enum('active','inactive')\" },\r",
                  "        { Field: 'created_at', Type: 'timestamp' }\r",
                  "    ];\r",
                  "\r",
                  "    expectedSchema.forEach(expected => {\r",
                  "        let actual = schema.find(col => col.Field === expected.Field);\r",
                  "        pm.expect(actual, `Column ${expected.Field} is missing!`).to.not.be.undefined;\r",
                  "        pm.expect(actual.Type).to.include(expected.Type);\r",
                  "    });\r",
                  "});\r",
                  "\r",
                  "// 3. Primary Key & Auto-Increment Validation\r",
                  "pm.test(\"Schema: ID Column is Primary Key and Auto-Increments\", function () {\r",
                  "    let idCol = schema.find(col => col.Field === 'id');\r",
                  "    pm.expect(idCol.Key).to.eql('PRI');\r",
                  "    pm.expect(idCol.Extra).to.include('auto_increment');\r",
                  "});\r",
                  "\r",
                  "// 4. Nullability Check (Data Integrity)\r",
                  "pm.test(\"Schema: Username and Email do not allow NULL\", function () {\r",
                  "    let usernameCol = schema.find(col => col.Field === 'username');\r",
                  "    let emailCol = schema.find(col => col.Field === 'email');\r",
                  "    \r",
                  "    pm.expect(usernameCol.Null).to.eql('NO');\r",
                  "    pm.expect(emailCol.Null).to.eql('NO');\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{ \"query\": \"DESCRIBE users\" }",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{bridge_url}}/query",
              "host": [
                "{{bridge_url}}"
              ],
              "path": [
                "query"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "02_Data_Mapping",
      "item": [
        {
          "name": "Validate User Record",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 1. Basic Response Check\r",
                  "pm.test(\"Status Code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "var dbResults = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Mapping: Record exists and fields are accurate\", function () {\r",
                  "    // Check if result is an array and not empty\r",
                  "    pm.expect(dbResults).to.be.an('array');\r",
                  "    pm.expect(dbResults.length).to.be.at.least(1);\r",
                  "\r",
                  "    var user = dbResults[0];\r",
                  "\r",
                  "    // Data Mapping Assertions\r",
                  "    pm.expect(user.username).to.eql(\"faizan_qa_lead\");\r",
                  "    pm.expect(user.email).to.eql(\"faizan.test@gmail.com\");\r",
                  "    pm.expect(user.status).to.eql(\"active\");\r",
                  "    \r",
                  "    // Verify System-Generated Fields\r",
                  "    pm.expect(user.id).to.be.a('number');\r",
                  "    pm.expect(user.created_at).to.not.be.null;\r",
                  "    \r",
                  "    console.log(`✅ Data Mapping Verified for ID: ${user.id}`);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"query\": \"SELECT * FROM users WHERE username = 'faizan_qa_lead'\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{bridge_url}}/query",
              "host": [
                "{{bridge_url}}"
              ],
              "path": [
                "query"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Timestamp Logic (Freshness Test)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Mapping: Created_at timestamp is logical (Freshness check)\", function () {\r",
                  "    var user = pm.response.json()[0];\r",
                  "    var dbTime = new Date(user.created_at).getTime();\r",
                  "    var currentTime = new Date().getTime();\r",
                  "    \r",
                  "    // Check if the record was created within the last 24 hours (86,400,000 ms)\r",
                  "    var timeDifference = currentTime - dbTime;\r",
                  "    \r",
                  "    pm.expect(timeDifference).to.be.below(86400000); \r",
                  "    console.log(\"✅ Timestamp Integrity: Record is fresh.\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"query\": \"SELECT * FROM users WHERE username = 'faizan_qa_lead'\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{bridge_url}}/query",
              "host": [
                "{{bridge_url}}"
              ],
              "path": [
                "query"
              ]
            },
            "description": "It ensures the DB isn't just putting any date, but a date that is recent."
          },
          "response": []
        },
        {
          "name": "Business Rule Validation: Email Formatting",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Mapping: Email follows Business Rule (Regex)\", function () {\r",
                  "    var user = pm.response.json()[0];\r",
                  "    \r",
                  "    // Regex to ensure the email in the DB is actually a valid email format\r",
                  "    var emailRegex = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/;\r",
                  "    \r",
                  "    pm.expect(user.email).to.match(emailRegex);\r",
                  "    pm.expect(user.email).to.include(\"@gmail.com\"); // Specific business requirement\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"query\": \"SELECT * FROM users WHERE username = 'faizan_qa_lead'\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{bridge_url}}/query",
              "host": [
                "{{bridge_url}}"
              ],
              "path": [
                "query"
              ]
            },
            "description": "check if the DB has \"cleaned\" Email it or if it follows the required pattern."
          },
          "response": []
        }
      ]
