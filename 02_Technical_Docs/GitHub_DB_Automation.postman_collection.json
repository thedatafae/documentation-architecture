              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Capture Initial DB Count\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    pm.environment.set(\"initial_count\", jsonData[0].total);\r",
                  "    console.log(\"Initial Rows: \" + jsonData[0].total);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\"query\": \"SELECT COUNT(*) AS total FROM users\"}",
              "options": {
                "raw": {
                  "language": "json"
