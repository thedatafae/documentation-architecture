        {
          "name": "4: Update & State Verification",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Persistence: State Transition Successful\", function () {\r",
                  "    pm.expect(pm.response.json().changedRows).to.eql(1);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n\"query\": \"UPDATE users SET status = 'inactive' WHERE username = 'persistence_test'\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{bridge_url}}/query",
              "host": [
                "{{bridge_url}}"
              ],
              "path": [
                "query"
              ]
            },
            "description": "Change the status."
          },
          "response": []
        },
        {
          "name": "5: The Delete / Cleanup",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Cleanup: Environment Reset Successful\", function () {\r",
                  "    const response = pm.response.json();\r",
                  "    \r",
                  "    // We expect at least the row we just created to be deleted\r",
                  "    pm.expect(response.affectedRows).to.be.at.least(1);\r",
                  "    \r",
                  "    console.log(`🧹 Cleanup complete. Deleted ${response.affectedRows} test records.`);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Post-Condition: Row Count Restored\", function () {\r",
                  "    // This is a great place to unset variables so the next run is fresh\r",
                  "    pm.environment.unset(\"initial_count\");\r",
                  "    pm.environment.unset(\"test_username\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"query\": \"DELETE FROM users WHERE id > 1 AND username LIKE '%test%'\"\r\n}",
