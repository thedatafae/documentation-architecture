    {
      "name": "04_Constraint_Security",
      "item": [
        {
          "name": "1: Unique Constraint Violation",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 1. We EXPECT a 500 error here because the DB is blocking a bad action\r",
                  "pm.test(\"Security: DB correctly blocks duplicate username\", function () {\r",
                  "    pm.response.to.have.status(500); \r",
                  "});\r",
                  "\r",
                  "// 2. Parse the error message\r",
                  "pm.test(\"Security: Error message confirms Unique Constraint violation\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    \r",
                  "    // Check if the error string contains the 'Duplicate entry' keyword\r",
                  "    pm.expect(jsonData.error).to.include(\"Duplicate entry\");\r",
                  "    pm.expect(jsonData.error).to.include(\"faizan_qa_lead\");\r",
                  "    \r",
                  "    console.log(\"🛡️ Database Guardrail Active: Duplicate prevented.\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"query\": \"INSERT INTO users (username, email) VALUES ('faizan_qa_lead', 'hacker@test.com')\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{bridge_url}}/query",
              "host": [
                "{{bridge_url}}"
              ],
              "path": [
                "query"
              ]
            },
            "description": "try to \"break\" the system by inserting a username that already exists in our permanent record (id: 1)."
          },
          "response": []
        },
        {
          "name": "2: Null Constraint Violation",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 1. Verify the DB Engine blocked the transaction\r",
                  "pm.test(\"Security: DB rejects record with missing mandatory email\", function () {\r",
                  "    pm.response.to.have.status(500); \r",
                  "});\r",
                  "\r",
                  "// 2. Validate the specific Error Message\r",
                  "pm.test(\"Security: Error message confirms NULL constraint violation\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    \r",
                  "    // This confirms the 'NOT NULL' constraint on the 'email' column is working\r",
                  "    pm.expect(jsonData.error).to.include(\"Field 'email' doesn't have a default value\");\r",
                  "    \r",
                  "    console.log(\"🛡️ Integrity Guardrail Active: Null record blocked.\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"query\": \"INSERT INTO users (username) VALUES ('no_email_user')\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{bridge_url}}/query",
              "host": [
                "{{bridge_url}}"
              ],
              "path": [
                "query"
              ]
            },
            "description": "Trying to insert a row without an email (which we set as NOT NULL)."
          },
          "response": []
        }
      ]
