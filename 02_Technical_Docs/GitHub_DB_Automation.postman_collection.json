        {
          "name": "2: Create User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Persistence: Verify Row Insertion\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "    // Note: mysql2 returns 'affectedRows' for INSERTs\r",
                  "    pm.expect(pm.response.json().affectedRows).to.eql(1);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n\"query\": \"INSERT INTO users (username, email, status) VALUES ('persistence_test', 'persist@test.com', 'active')\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{bridge_url}}/query",
              "host": [
                "{{bridge_url}}"
              ],
              "path": [
                "query"
              ]
            },
            "description": "Create a user."
          },
          "response": []
