        {
          "name": "3: Verify Persistence (Post-Check)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Persistence: Total Count Increased\", function () {\r",
                  "    var currentCount = pm.response.json()[0].total;\r",
                  "    var initialCount = parseInt(pm.environment.get(\"initial_count\"));\r",
                  "    \r",
                  "    pm.expect(currentCount).to.eql(initialCount + 1);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\"query\": \"SELECT COUNT(*) AS total FROM users\"}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{bridge_url}}/query",
              "host": [
                "{{bridge_url}}"
              ],
              "path": [
                "query"
              ]
            },
            "description": "Verify total rows = Before + 1."
          },
          "response": []
