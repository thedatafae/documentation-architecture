        {
          "name": "Test 3.2: Transfer & Verify (POST)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 1. Check if the API said Success\r",
                  "pm.test(\"FT_001: Transfer API Success\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "// 2. The Chain Verification (Logic Check)\r",
                  "// We send a NEW request from inside this test to check the balance again\r",
                  "const baseUrl = pm.environment.get(\"base_url\");\r",
                  "const initialBalance = parseFloat(pm.environment.get(\"initial_balance\"));\r",
                  "const transferAmount = 100.00;\r",
                  "\r",
                  "pm.sendRequest(`${baseUrl}/accounts`, function (err, res) {\r",
                  "    if (err) { console.log(err); } \r",
                  "    else {\r",
                  "        pm.test(\"FT_002: Chain Check - Sender balance deducted correctly\", function () {\r",
                  "            const accounts = res.json();\r",
                  "            const faizan = accounts.find(acc => acc.id === 1);\r",
                  "            const expectedBalance = initialBalance - transferAmount;\r",
                  "            \r",
                  "            pm.expect(parseFloat(faizan.balance)).to.eql(expectedBalance);\r",
                  "        });\r",
                  "    }\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n\"sender_id\": 1,\r\n\"receiver_id\": 2,\r\n\"amount\": 100.00\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/transfer",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "transfer"
              ]
            }
          },
          "response": []
        }
      ]
