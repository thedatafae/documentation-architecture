    {
      "name": "Backend Logic Test (The \"Acid\" Test)",
      "item": [
        {
          "name": "Test 5.1: The Rollback Verification (Post-500 Check)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// This runs BEFORE the request is sent\r",
                  "// It captures the \"True\" balance from the DB right now\r",
                  "const baseUrl = pm.environment.get(\"base_url\");\r",
                  "\r",
                  "pm.sendRequest(`${baseUrl}/accounts`, function (err, res) {\r",
                  "    const faizan = res.json().find(acc => acc.id === 1);\r",
                  "    pm.environment.set(\"balance_before_error\", faizan.balance);\r",
                  "    console.log(\"Pre-test Balance Captured: \" + faizan.balance);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"BL_001: Rollback Integrity - Balance did not change after 500 Error\", function () {\r",
                  "    // 1. We expect the server to have failed (because we sent a ghost user)\r",
                  "    pm.expect(pm.response.code).to.be.oneOf([500, 404, 400]);\r",
                  "\r",
                  "    // 2. We trigger a fresh check to see the current balance\r",
                  "    const baseUrl = pm.environment.get(\"base_url\");\r",
                  "    const balanceBefore = parseFloat(pm.environment.get(\"balance_before_error\"));\r",
                  "\r",
                  "    pm.sendRequest(`${baseUrl}/accounts`, function (err, res) {\r",
                  "        const faizan = res.json().find(acc => acc.id === 1);\r",
                  "        const balanceAfter = parseFloat(faizan.balance);\r",
                  "\r",
                  "        pm.test(\"Verification: Balance After (\" + balanceAfter + \") == Before (\" + balanceBefore + \")\", function() {\r",
                  "            pm.expect(balanceAfter).to.eql(balanceBefore);\r",
                  "        });\r",
                  "    });\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "protocolProfileBehavior": {
            "disableBodyPruning": true
          },
          "request": {
            "method": "GET",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\"sender_id\": 1, \"receiver_id\": 9999, \"amount\": 100}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/accounts",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "accounts"
              ]
            },
            "description": "- **Scenario:** We just got a `500 error` from the Ghost User test (Test 4.3).\n    \n- **The Goal:** Prove that even though the server \"crashed,\" the sender's money was **not** deducted."
          },
          "response": []
        }
      ]
    }
  ]
