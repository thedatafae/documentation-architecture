    {
      "name": "CRUD Testing",
      "item": [
        {
          "name": "Test 3.1: Get Initial Balance (GET)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Capture Initial Balance\", function () {\r",
                  "    const jsonData = pm.response.json();\r",
                  "    const faizan = jsonData.find(acc => acc.id === 1);\r",
                  "    \r",
                  "    // Save the balance to the environment\r",
                  "    pm.environment.set(\"initial_balance\", faizan.balance);\r",
                  "    console.log(\"Initial Balance Captured: \" + faizan.balance);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
